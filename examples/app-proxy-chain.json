{
  "services": [
    {
      "type": "Independent",
      "name": "public_api",
      "start-command": "go run ./cmd/public-api",
      "stop-command": "systemctl stop public-api",
      "status-command": "systemctl status public-api",
      "handlers": [
        {
          "type": "Replier",
          "socket": {
            "id": "public_1",
            "port": 4101
          },
          "command-deps": [
            {
              "command": "call-user-api",
              "proxies": [
                "auth_proxy",
                "audit_proxy"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "auth_proxy",
      "start-command": "go run ./cmd/auth-proxy",
      "stop-command": "SIGTERM",
      "handlers": [
        {
          "type": "Replier",
          "socket": {
            "id": "auth_1",
            "port": 4201
          },
          "command-deps": [
            {
              "command": "authorize",
              "proxies": [
                "audit_proxy"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Proxy",
      "name": "audit_proxy",
      "start-command": "go run ./cmd/audit-proxy",
      "stop-command": "SIGTERM",
      "handlers": [
        {
          "type": "Replier",
          "socket": {
            "id": "audit_1",
            "port": 4301
          },
          "command-deps": [
            {
              "command": "record-audit",
              "extensions": [
                "user_service"
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Independent",
      "name": "user_service",
      "start-command": "go run ./cmd/user-service",
      "stop-command": "SIGTERM",
      "handlers": [
        {
          "type": "Replier",
          "socket": {
            "id": "user_api_1",
            "port": 4401
          }
        }
      ]
    }
  ]
}
